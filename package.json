{
  "name": "digisafe-europe",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mcp": "npm run mcp:start-all & npm run dev",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "lint:css": "stylelint \"src/**/*.{css}\" --allow-empty-input",
    "typecheck": "tsc --noEmit",
    "lint:all": "npm run lint && npm run lint:css && npm run typecheck",
    "storybook": "storybook dev --port 6006",
    "storybook:build": "storybook build",
    "preview": "vite preview",
    "mcp:start-all": "node --loader tsx src/lib/mcp-orchestrator.ts start-all",
    "mcp:status": "node --loader tsx src/lib/mcp-orchestrator.ts status",
    "mcp:stop-all": "node --loader tsx src/lib/mcp-orchestrator.ts stop-all",
    "mcp:sequential-thinking": "npx @modelcontextprotocol/server-sequential-thinking",
    "mcp:context7": "npx @upstash/context7-mcp"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^16.5.0",
    "@material-tailwind/react": "^2.1.9",
    "@paypal/react-paypal-js": "^8.1.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@react-pdf/renderer": "^3.3.8",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.2.0",
    "@tanstack/react-query": "^5.18.1",
    "@tanstack/react-query-devtools": "^5.90.2",
    "chart.js": "^4.4.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "firebase": "^10.8.0",
    "framer-motion": "^11.0.3",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.50.0",
    "react-router-dom": "^6.22.0",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@modelcontextprotocol/server-sequential-thinking": "^2025.7.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^20.11.19",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.8",
    "@upstash/context7-mcp": "^1.0.26",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "eslint-plugin-sonarjs": "^3.0.5",
    "eslint-plugin-unicorn": "^62.0.0",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "storybook": "^8.6.14",
    "stylelint": "^16.25.0",
    "stylelint-config-standard": "^39.0.1",
    "stylelint-config-tailwindcss": "^1.0.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
